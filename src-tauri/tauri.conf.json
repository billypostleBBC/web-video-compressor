{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Web Video Compressor",
  "version": "0.1.0",
  "identifier": "uk.co.bbcstoryworks.web-video-compressor",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Web Video Compressor",
        "width": 474,
        "height": 464,
        "minWidth": 474,
        "minHeight": 340,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 20
        },
        "hiddenTitle": true,
        "backgroundColor": "#101114",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/web-video-compressor.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/bin/ffmpeg": "bin/ffmpeg",
      "resources/bin/ffmpeg.LICENSE": "bin/ffmpeg.LICENSE",
      "resources/bin/ffmpeg.README": "bin/ffmpeg.README"
    },
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "12.0"
    }
  }
}
