---
const cacheVersion = "webflow-4";
const appBasePath = "/web-video-compressor";
const assetPath = (filename) => `${appBasePath}/${filename}?v=${cacheVersion}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Web Video Compressor</title>
    <link rel="icon" href="data:," />
    <link rel="stylesheet" href={assetPath("styles.css")} />
  </head>
  <body>
    <div class="window-drag-region" data-tauri-drag-region aria-hidden="true"></div>
    <div class="app-title" data-tauri-drag-region>Web Video Compressor</div>
    <main class="app-shell">
      <div id="toolStatus" class="tool-alert" role="alert" hidden></div>

      <div class="accordion" aria-label="Compression workflow">
        <section class="accordion-section accordion-section--open accordion-section--chevron-open" data-section="source">
          <button
            id="sourceToggle"
            class="accordion-toggle"
            type="button"
            aria-expanded="true"
            aria-controls="sourcePanel"
          >
            <span class="accordion-title">Source</span>
            <span id="sourceSubtitle" class="accordion-subtitle">No files selected</span>
            <span class="accordion-chevron" aria-hidden="true"></span>
          </button>
          <div id="sourcePanel" class="accordion-panel">
            <div id="dropZone" class="source-drop" aria-label="Drop .mov or .mp4 video files">
              <p class="source-drop__heading">Drag and drop .mov or .mp4 files anywhere in this area</p>
              <p class="source-drop__copy">or click the button below to browse your computer</p>
              <div id="sourceSelection" class="source-selection" hidden></div>
              <p id="sourceGuidance" class="source-guidance" hidden></p>
              <div class="button-row source-actions">
                <button id="selectFileButton" type="button" class="primary">Choose file</button>
                <button id="resetButton" type="button" class="secondary" hidden disabled>Reset</button>
              </div>
              <span id="selectionText" class="sr-only">No source selected</span>
              <span id="outputText" class="sr-only"></span>
            </div>
          </div>
        </section>

        <section class="accordion-section" data-section="compression">
          <button
            id="compressionToggle"
            class="accordion-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="compressionPanel"
          >
            <span class="accordion-title">Compression</span>
            <span id="compressionSubtitle" class="accordion-subtitle">Medium</span>
            <span class="accordion-chevron" aria-hidden="true"></span>
          </button>
          <div id="compressionPanel" class="accordion-panel" hidden>
            <div class="compression-card">
              <div class="quality-ticks">
                <span>Low</span>
                <span class="quality-tick--active">Medium</span>
                <span>High</span>
              </div>
              <input id="qualitySlider" type="range" min="0" max="2" step="1" value="1" />
              <p id="qualityDescription" class="quality-description">Default, for balanced quality and size</p>
            </div>
            <span id="qualityLabel" class="sr-only">Medium</span>
          </div>
        </section>

        <section class="accordion-section" data-section="output">
          <button
            id="outputToggle"
            class="accordion-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="outputPanel"
          >
            <span class="accordion-title">Output</span>
            <span id="outputSubtitle" class="accordion-subtitle">0 outputs</span>
            <span class="accordion-chevron" aria-hidden="true"></span>
          </button>
          <div id="outputPanel" class="accordion-panel" hidden>
            <div class="output-card">
              <p id="summaryText" class="muted output-summary">No videos queued.</p>
              <div id="queueList" class="queue-list">
                <p class="muted">No outputs queued.</p>
              </div>
              <div id="runActions" class="button-row output-actions">
                <button id="downloadZipButton" type="button" class="secondary" hidden disabled>Download ZIP</button>
                <button id="outputActionButton" type="button" disabled>Start compression</button>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>

    <script src={assetPath("export-plan.js")}></script>
    <script src={assetPath("zip-download.js")}></script>
    <script src={assetPath("tauri-adapter.js")}></script>
    <script src={assetPath("browser-adapter.js")}></script>
    <script src={assetPath("renderer.js")}></script>
  </body>
</html>
